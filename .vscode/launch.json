{
    "version": "0.2.0",
    "configurations": [
        
        
        {
            "name": "(gdb) Launch",
            "type": "cppdbg",
            "request": "launch",
            // Resolved by CMake Tools:
            "program": "${workspaceFolder}/projects/geometric-flow/build_debug/bin/main_cluster",
            "args": ["../Config_files/Wrapping_manual.json","1"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/projects/geometric-flow/build_debug/",
            "environment": [
                {
                    "name": "PATH",
                    "value": "$PATH:${workspaceFolder}/projects/geometric-flow/build_debug/bin"
                },
                {
                    "name": "CFLAGS",
                    "value": "-fsanitize=address"
                },
                {
                    "name": "CXXFLAGS",
                    "value": "-fsanitize=address"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                }    
            ]
        }
    ]
}